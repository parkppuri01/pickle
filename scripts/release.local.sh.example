# Template for local release secrets.
#
# Setup:
#   cp scripts/release.local.sh.example scripts/release.local.sh
#   then fill in your Developer ID identity + notarytool keychain profile name.
#
# release.local.sh is gitignored, so your signing/notary details never get committed.
export PICKLE_SIGN_IDENTITY="Developer ID Application: YOUR NAME (YOUR_TEAM_ID)"
export PICKLE_NOTARY_PROFILE="your-notarytool-keychain-profile"
